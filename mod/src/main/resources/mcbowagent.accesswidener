accessible	method	net/minecraft/client/render/GameRenderer	getFov	(Lnet/minecraft/client/render/Camera;FZ)D

# Expose NativeImage.pointer so FrameCapture can swizzle ABGR -> BGR via a single MemoryUtil bulk-read
# instead of 100k JNI calls to getPixelColor per frame. Required for the v0.7.0 60Hz capture path —
# at 60 Hz the per-pixel loop would consume ~35% of the render thread budget.
accessible	field	net/minecraft/client/texture/NativeImage	pointer	J
