# Normalize text to LF in the repo; keep platform-correct line endings on checkout.
* text=auto eol=lf
*.bat        text eol=crlf
*.mcfunction text eol=lf

# Binary assets — never touch line endings / never diff as text.
*.jar binary
*.gif binary
*.png binary
*.jpg binary
*.mp4 binary
*.onnx binary
*.pt binary
